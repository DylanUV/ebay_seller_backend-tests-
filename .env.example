# Copia este archivo como .env y completa tus datos.
# NUNCA subas el .env real a GitHub (ya debería estar en .gitignore).

# Credenciales de tu app en https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=tu_client_id_aqui
EBAY_CLIENT_SECRET=tu_client_secret_aqui

# Usuario vendedor por defecto si el frontend no manda ?seller=
DEFAULT_SELLER_USERNAME=

# Puerto local (Render lo ignora, él inyecta su propio PORT automáticamente)
PORT=8080

# Orígenes permitidos por CORS, separados por comas (sin espacios).
# Ejemplo local: http://localhost:8080,http://localhost:5000
# Ejemplo con tu web desplegada: https://mi-ebay-app.pages.dev
CORS_ORIGINS=http://localhost:8080
